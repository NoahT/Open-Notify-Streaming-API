{
    "ENVIRONMENT": "development",
    "REDIS_CLIENT": {
        "HOST": "localhost",
        "PORT": 6379,
        "CONNECT": {
            "TIMEOUT": 5.000
        },
        "SUBSCRIBE": {
            "SLEEP_TIME": 5.000
        },
        "CHANNEL": "iss_location",
        "DECODE_RESPONSES": true
    },
    "ROUTES": {
        "V1_ISS_EVENTS": {
            "PARAMS": {
                "WINDOW": {
                    "MINIMUM_VALUE": 10,
                    "MAXIMUM_VALUE": 600
                }
            }
        }
    }
}