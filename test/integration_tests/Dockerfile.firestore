FROM node:18-alpine

# Install Java (required by Firestore emulator) and Firebase CLI
RUN apk add --no-cache openjdk11-jre

# Install Firebase CLI
RUN npm install -g firebase-tools

# Set working directory
WORKDIR /app

# Copy Firebase configuration files from the same directory
COPY firebase.json .firebaserc ./

# Expose Firestore emulator port
EXPOSE 8080

# Start Firestore emulator, binding to all interfaces
CMD [ "firebase", "emulators:start", "--only", "firestore", "--project", "open-notify" ]
